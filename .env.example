# Satellite Environmental Intelligence Platform - Environment Variables

# API Keys
# Google Earth Engine (Requires Service Account JSON path or initialized ee credentials)
GEE_SERVICE_ACCOUNT=""
GEE_PRIVATE_KEY=""

# NASA Earthdata API
NASA_USERNAME=""
NASA_PASSWORD=""

# Copernicus Sentinel Hub
SENTINEL_CLIENT_ID=""
SENTINEL_CLIENT_SECRET=""

# Custom Historical Data API (5-10 years)
# If you have an API for long-term historical environmental data (e.g., OpenWeatherMap, visualcrossing), put the key here:
EXTERNAL_HISTORICAL_API_KEY="your_api_key_here"

# Configuration
HOST="0.0.0.0"
PORT="8000"
ENVIRONMENT="development"
